# Bistro Buzzer Environment Configuration

# ─── Server ───────────────────────────────────────────────────────────────────

# Port for Express server
PORT=5000

# Node environment (development | production)
NODE_ENV=development

# Database connection (PostgreSQL/Neon)
DATABASE_URL=postgresql://user:password@host/database

# Session secret for cookie signing
SESSION_SECRET=your-secret-here-change-in-production

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ─── Web Push Notifications ───────────────────────────────────────────────────

# VAPID keys for web push (generate with: npx web-push generate-vapid-keys --json)
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# ─── AI Services ──────────────────────────────────────────────────────────────

# DeepSeek API key for AI guest assistant and product ordering
DEEPSEEK_API_KEY=sk-...

# Optional: Google Custom Search API for web search integration
# GOOGLE_SEARCH_API_KEY=your-google-api-key
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# Optional: SerpApi for web search (alternative to Google)
# SERPAPI_API_KEY=your-serpapi-key

# ─── Stability AI ─────────────────────────────────────────────────────────────

# Stability AI API key for generating product images
STABILITY_API_KEY=sk-...

# ─── Frontend (VITE_* prefix required for Vite to expose to browser) ──────────

# VAPID public key (exposed to frontend for push subscription)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Logging level
VITE_LOG_LEVEL=info
